{
  "projects": {
    "default": "qr-menu-19cd1"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      ".firebase/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulator": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "hub": {
      "port": 4400
    }
  }
}
